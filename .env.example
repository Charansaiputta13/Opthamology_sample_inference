# Environment Configuration for DR Classification System
# Copy this file to .env and customize as needed

# =====================
# MODEL CONFIGURATION
# =====================
# Path to trained PyTorch model file (.pth)
MODEL_PATH=pretrained/dr_mobilenetv2_5class.pth

# =====================
# DATA PATHS
# =====================
DATA_DIR=data/images
OUTPUT_DIR=outputs

# =====================
# INFERENCE SETTINGS
# =====================
# Confidence threshold for "needs review" flag (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.6

# Blur detection threshold (Laplacian variance, lower = more blurry)
BLUR_THRESHOLD=100.0

# Minimum acceptable image resolution (pixels)
MIN_IMAGE_SIZE=256

# Batch size for inference (higher = faster but more memory)
BATCH_SIZE=16

# =====================
# LOGGING
# =====================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory
LOG_DIR=outputs/logs
# =====================
# CAM VISUALIZATION (PyTorch-based Explainability)
# =====================
# Default CAM method when not specified
# Options: GradCAM, GradCAM++, ScoreCAM, EigenCAM, LayerCAM
DEFAULT_CAM_METHOD=GradCAM

# CAM overlay transparency (0.0 = invisible, 1.0 = fully opaque)
CAM_ALPHA=0.4